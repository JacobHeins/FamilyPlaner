# Copy this file to .env and fill in the values before running docker-compose.prod.yml
# chmod 600 .env — ensure only the deploy user can read it

# GitHub repo path used to resolve the image (e.g. myorg/family-planer)
GITHUB_REPOSITORY=

# Tag of the image to deploy (e.g. latest or a specific git sha/semver tag)
IMAGE_TAG=latest

# PostgreSQL
DB_NAME=familyplaner
DB_USERNAME=
DB_PASSWORD=
